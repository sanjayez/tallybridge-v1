    "start:web": "node scripts/start-web.js",
    "web:build": "next build apps/web",
    "web:config-check": "node scripts/web-config-check.js",
    "agent:compat-check": "node scripts/agent-queue-compat-check.js",
    "hosted:bundle-check": "node scripts/hosted-bundle-check.js",
    "db:migration-check": "node scripts/db-migration-check.js",
    "profile:adoption-check": "node scripts/profile-adoption-check.js",
    "hosted:smoke": "node scripts/hosted-smoke-test.js",
    "agent": "node agent/cmd/tallybridge-agent/index.js",
    "demo": "node scripts/demo-cli.js",
    "mock:tally": "node scripts/mock-tally-server.js",
    "syntax:check": "node scripts/syntax-check.js",
    "checkpoint": "node scripts/checkpoint-runner.js",
    "tally:test": "node tally-test.js",
