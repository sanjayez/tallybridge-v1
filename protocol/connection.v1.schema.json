{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./connection.v1.schema.json",
  "title": "TallyBridge Connection Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connection_id",
    "tenant_id",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "connection_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "pairing_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "waiting_for_tally",
        "active",
        "active_degraded",
        "offline",
        "error",
        "decommissioned"
      ]
    },
    "install_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "admin",
        "user",
        null
      ]
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "xml_only",
        "event_bridge",
        null
      ]
    },
    "tally_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "companies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "active_company": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_heartbeat": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
