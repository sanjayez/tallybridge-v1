{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./result.v1.schema.json",
  "title": "TallyBridge Command Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command_id",
    "connection_id",
    "status",
    "completed_at"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "connection_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "retryable_failure"
      ]
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "data": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "code",
        "message",
        "retryable"
      ]
    }
  }
}
